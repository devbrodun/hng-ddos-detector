# Change: slack_webhook_url: "https://hooks.slack.com/services/YOUR/ACTUAL/WEBHOOK"# Thresholds
z_score_threshold: 3.0 # Flag if z-score exceeds this rate_multiplier: 5.0 # Flag if rate > 5x baseline mean error_rate_multiplier: 3.0 # Tighten 
thresholds if 4xx/5xx is 3x baseline
# Build and launch Windows
docker compose up -d --buildsliding_window_seconds: 60 # Per-IP and global deque window baseline_window_minutes: 30 # Rolling baseline window 
baseline_recalc_interval: 60 # Recalculate baseline every N seconds

# Unban schedule (seconds) Watch detector logsunban_schedule:
docker compose logs -f detector

# Confirm Nginx is writing JSON logs
docker compose exec nginx tail -f /var/log/nginx/hng-access.log  - 600      # 10 minutes
  - 1800     # 30 minutes
  - 7200     # 2 hours
  - -1       # -1 = permanent

# Slack
slack_webhook_url: "https://hooks.slack.com/services/YOUR/WEBHOOK/HERE"

# Dashboard
dashboard_host: "0.0.0.0"
dashboard_port: 8080

# Paths
log_path: "/var/log/nginx/hng-access.log"
audit_log_path: "/var/log/detector-audit.log"

# Baseline floors (prevent divide-by-zero with no traffic)
baseline_floor_mean: 0.1
baseline_floor_stddev: 0.1
